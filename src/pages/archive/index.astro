---
import { getPaginatedTimelineEntries, getDateFilters } from '@data/everything';
import TimelineArchiveLayout from '@layouts/TimelineArchiveLayout.astro';

const { posts, currentPage, totalPages, totalPosts } = await getPaginatedTimelineEntries(1);
const dateFilters = await getDateFilters();
---

<TimelineArchiveLayout
  groups={posts}
  currentPage={currentPage}
  totalPages={totalPages}
  totalPosts={totalPosts}
  dateFilters={dateFilters}
/>
