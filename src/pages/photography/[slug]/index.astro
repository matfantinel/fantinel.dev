---
import { getPaginatedPhotographies } from '@data/photographies';
import { getPaginatedTimelineEntries } from '@data/everything';
import PhotographyLayout from '@layouts/PhotographyLayout.astro';

export async function getStaticPaths() {
  const { photographies } = await getPaginatedPhotographies(1, { postsPerPage: 999 });

  const paths = photographies.map((photography) => ({
    params: { slug: photography.slug },
    props: { photography },
  }));

  return paths;
}

const latestTimelineEntries = (await getPaginatedTimelineEntries(1)).posts;
const { photography } = Astro.props;
---

<PhotographyLayout photography={photography} latestTimelineEntries={latestTimelineEntries} />
