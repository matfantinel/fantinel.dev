---
import { getPaginatedTimelineEntries } from '@data/everything';
import { getPaginatedReviews } from '@data/quickReviews';
import QuickReviewLayout from '@layouts/QuickReviewLayout.astro';

export async function getStaticPaths() {
  const { reviews } = await getPaginatedReviews(1, undefined, undefined, { postsPerPage: 999 });

  const paths = reviews.map((review) => ({
    params: { slug: review.slug },
    props: { review },
  }));

  return paths;
}

const latestTimelineEntries = (await getPaginatedTimelineEntries(1)).posts;
const { review } = Astro.props;
---

<QuickReviewLayout review={review} latestTimelineEntries={latestTimelineEntries} />
