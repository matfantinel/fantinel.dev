---
import { getPaginatedReviews, getTypeFilters, getRatingFilters, getYearFilters } from '@data/quickReviews';
import QuickReviewsArchiveLayout from '@layouts/QuickReviewsArchiveLayout.astro';

const { reviews, currentPage, totalPages, totalReviews } = await getPaginatedReviews(1);

const [typeFilters, ratingFilters, yearFilters] = await Promise.all([
  getTypeFilters(),
  getRatingFilters(),
  getYearFilters(),
]);
---

<QuickReviewsArchiveLayout
  reviews={reviews}
  currentPage={currentPage}
  totalPages={totalPages}
  totalReviews={totalReviews}
  typeFilters={typeFilters}
  ratingFilters={ratingFilters}
  yearFilters={yearFilters}
/>
