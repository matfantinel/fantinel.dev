---
import { getPaginatedCoolLinks, getTagFilters, getDateFilters } from '@data/coolLinks';
import CoolLinksArchiveLayout from '@layouts/CoolLinksArchiveLayout.astro';

const { links, currentPage, totalPages, totalLinks } = await getPaginatedCoolLinks(1);
const [tagFilters, dateFilters] = await Promise.all([
  getTagFilters(),
  getDateFilters(),
]);
---

<CoolLinksArchiveLayout
  links={links}
  currentPage={currentPage}
  totalPages={totalPages}
  totalLinks={totalLinks}
  tagFilters={tagFilters}
  dateFilters={dateFilters}
/>
