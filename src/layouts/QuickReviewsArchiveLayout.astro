---
import QuickReviewCards from '@components/molecules/QuickReviewCards';
import type { QuickReview } from '@schemas/quick-review';
import { getTypeFromLowercaseKey, getRatingFromLowercaseKey, getRatingSlug } from '@schemas/quick-review-types';
import type { FilterTag, FilterGroup } from '@schemas/filter';
import BaseArchiveLayout from './BaseArchiveLayout.astro';
import { getSiteMeta, getQuickReviewArchiveConfig } from '@data/yaml';
const siteMeta = getSiteMeta();
const pageData = getQuickReviewArchiveConfig();

interface Props {
  reviews: QuickReview[];
  currentPage: number;
  totalPages: number;
  totalReviews: number;
  currentType?: string;
  currentRating?: string;
  currentYear?: string;
  typeFilters?: FilterTag[];
  ratingFilters?: FilterTag[];
  yearFilters?: FilterTag[];
}

const {
  reviews,
  currentPage,
  totalPages,
  totalReviews,
  currentType: currentTypeParam,
  currentRating: currentRatingParam,
  currentYear,
  typeFilters,
  ratingFilters,
  yearFilters,
}: Props = Astro.props;

// Convert lowercase params to proper enum values
const currentType = currentTypeParam ? getTypeFromLowercaseKey(currentTypeParam) : undefined;
const currentRating = currentRatingParam ? getRatingFromLowercaseKey(currentRatingParam) : undefined;

const filterGroups: FilterGroup[] = [];
if (typeFilters) {
  filterGroups.push({ label: 'Filter by media', tags: typeFilters });
}
if (ratingFilters) {
  filterGroups.push({ label: 'Filter by rating', tags: ratingFilters });
}
if (yearFilters) {
  filterGroups.push({ label: 'Filter by year (of review)', tags: yearFilters });
}

let paginationBaseUrl = '/quick-reviews';
if (currentType) paginationBaseUrl += `/type/${currentType.toLowerCase()}`;
if (currentRating) paginationBaseUrl += `/rating/${getRatingSlug(currentRating)}`;

let summaryText = '';
if (totalReviews) {
  summaryText = `${totalReviews} reviews`;
  if (currentType) summaryText += ` for "${currentType}"`;
  if (currentRating) summaryText += ` rated "${currentRating}"`;
  if (currentYear) summaryText += ` from ${currentYear}`;
}
---

<BaseArchiveLayout
  className='l-quick-reviews-archive'
  title={pageData.pageTitle}
  image={pageData.pagePreviewImage ? siteMeta.baseUrl + pageData.pagePreviewImage : undefined}
  heroTitle={pageData.hero?.title}
  heroBody={pageData.hero?.body}
  baseUrl='/quick-reviews'
  basePaginationUrl={paginationBaseUrl}
  currentPage={currentPage}
  totalPages={totalPages}
  filterGroups={filterGroups}
  summaryText={summaryText}
>
  <div class='l-quick-reviews-archive__explainer u-markdown'>
    <p>
      This idea and overall review layout were totally stolen from Matt Birchler and his <a
        href='https://quickreviews.app'
        target='_blank'
      >
        Quick Reviews
      </a> web app. Check it out if you want to create yours!
    </p>
  </div>

  {!reviews.length && <p class='u-h4'>No reviews found</p>}

  {
    // I'm passing reviews as a prop here to avoid having multiple
    // Elements with client:load. Having multiple islands like that
    // can cause issues.
    reviews && <QuickReviewCards reviews={reviews} client:load />
  }
</BaseArchiveLayout>

<style lang='scss'>
  @use '/src/styles/mixins';

  :root:has(.l-quick-reviews-archive) {
    @include mixins.set-accent-color('quick-review');
  }

  :global(.l-base-archive.l-quick-reviews-archive) {
    --content-max-width: 780px;
  }

  .l-quick-reviews-archive {
    &__explainer {
      text-align: center;
    }
  }
</style>
