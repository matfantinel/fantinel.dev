---
import PostsTimeline from '@components/organisms/PostsTimeline/PostsTimeline.svelte';
import type { BlogPost } from '@schemas/blog';
import type { CoolLink } from '@schemas/cool-link';
import type { Photography } from '@schemas/photography';
import type { QuickReview } from '@schemas/quick-review';
import type { FilterGroup } from '@schemas/filter';
import BaseArchiveLayout from './BaseArchiveLayout.astro';

interface Props {
  groups: { date: string, posts: { type: string, data: BlogPost | QuickReview | CoolLink | Photography }[] }[];
  currentPage: number;
  totalPages: number;
  totalPosts: number;
  currentDate?: string;
  dateFilters?: FilterGroup[];
}

const {
  groups,
  currentPage,
  totalPages,
  totalPosts,
  currentDate,
  dateFilters,
}: Props = Astro.props;

const filterGroups: FilterGroup[] = [];
if (dateFilters) {
  filterGroups.push({ label: 'Filter by month', groups: dateFilters });
}

let summaryText = '';
if (totalPosts && currentDate) {
  summaryText = `${totalPosts} posts`;
  summaryText += ` from ${currentDate}`;
}
---

<BaseArchiveLayout
  className='l-timeline-archive'
  title='Archive'
  heroTitle='Archive'
  heroBody="A chronological view of *everything* I've posted here, since the beginning of time (or the blog's inception, whichever comes first)."
  baseUrl='/archive'
  currentPage={currentPage}
  totalPages={totalPages}
  summaryText={summaryText}
>
  <PostsTimeline
    postGroups={groups}
    baseUrl='/archive'
    filterGroups={filterGroups}
    client:load
  />
</BaseArchiveLayout>
